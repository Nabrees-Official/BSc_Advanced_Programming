<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <servlet>
        <servlet-name>HelloServlet</servlet-name>
        <servlet-class>com.roomreservation.controller.HelloServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>HelloServlet</servlet-name>
        <url-pattern>/hello</url-pattern>
    </servlet-mapping>

    <!-- OPTIONAL: Make / open /hello automatically when you open just the app root -->
    <welcome-file-list>
        <welcome-file>hello</welcome-file>
    </welcome-file-list>

    <servlet>
        <servlet-name>AddReservationServlet</servlet-name>
        <servlet-class>com.roomreservation.controller.AddReservationServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AddReservationServlet</servlet-name>
        <url-pattern>/addReservation</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CalculateBillServlet</servlet-name>
        <servlet-class>com.roomreservation.controller.CalculateBillServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>CalculateBillServlet</servlet-name>
        <url-pattern>/calculateBill</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.roomreservation.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MenuServlet</servlet-name>
        <servlet-class>com.roomreservation.controller.MenuServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MenuServlet</servlet-name>
        <url-pattern>/menu</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.roomreservation.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.roomreservation.filter.AuthFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <servlet>
        <servlet-name>ViewReservationServlet</servlet-name>
        <servlet-class>com.roomreservation.controller.ViewReservationServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ViewReservationServlet</servlet-name>
        <url-pattern>/viewReservation</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ListReservationsServlet</servlet-name>
        <servlet-class>com.roomreservation.controller.ListReservationsServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ListReservationsServlet</servlet-name>
        <url-pattern>/listReservations</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EditReservationServlet</servlet-name>
        <servlet-class>com.roomreservation.controller.EditReservationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditReservationServlet</servlet-name>
        <url-pattern>/editReservation</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteReservationServlet</servlet-name>
        <servlet-class>com.roomreservation.controller.DeleteReservationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteReservationServlet</servlet-name>
        <url-pattern>/deleteReservation</url-pattern>
    </servlet-mapping>

</web-app>